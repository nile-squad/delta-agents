{
  "name": "delta-agents",
  "version": "0.0.1",
  "description": "Deterministic autonomous control plane for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "vitest run && tsc --noEmit && tsup",
    "bundle": "tsup",
    "test:e2e": "tsup && vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/hussein-kizz/delta-agents#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hussein-kizz/delta-agents.git"
  },
  "bugs": {
    "url": "https://github.com/hussein-kizz/delta-agents/issues"
  },
  "keywords": [
    "ai-agents",
    "autonomous-agents",
    "governance",
    "control-plane",
    "state-machine",
    "supervision",
    "task-orchestration",
    "agent-safety",
    "human-oversight",
    "typescript"
  ],
  "author": "Hussein Kizz",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@llamaindex/liteparse": "^2.4.0",
    "@types/ms": "^2.1.0",
    "@vitest/ui": "^4.0.15",
    "exa-js": "2.14.0",
    "sharp": "^0.35.2",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "ms": "^2.1.3",
    "nanoid": "^5.1.11",
    "openai": "^6.44.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "slang-ts": "^0.0.7",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@llamaindex/liteparse": "^2.4.0",
    "exa-js": "^2.14.0",
    "sharp": "^0.35.2"
  },
  "peerDependenciesMeta": {
    "@llamaindex/liteparse": {
      "optional": true
    },
    "exa-js": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  }
}
