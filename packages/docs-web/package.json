{
  "name": "delta-agents-docs",
  "description": "Delta Agents documentation",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build && cp serve.json build/client/serve.json",
    "dev": "react-router dev",
    "start": "serve ./build/client",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^7.13.2",
    "fumadocs-core": "^16.10.7",
    "fumadocs-mdx": "^15.0.13",
    "fumadocs-ui": "^16.10.7",
    "isbot": "^5.1.36",
    "lucide-react": "^1.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.13.2",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@react-router/dev": "^7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.0",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  }
}
