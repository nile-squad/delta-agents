{
  "name": "delta-agents-docs",
  "description": "Documentation site for delta-agents, a deterministic governance and control-plane engine for AI agents",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/generate-home-code.ts && rspress build",
    "postbuild": "cp doc_build/llms.txt doc_build/llms-full.txt docs/public/",
    "check": "biome check --write",
    "dev": "bun run scripts/generate-home-code.ts && rspress dev",
    "format": "biome format --write",
    "preview": "rspress preview"
  },
  "dependencies": {
    "@rspress/core": "^2.0.2",
    "react-icons": "^5.5.0",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@rspress/plugin-llms": "^2.0.3",
    "@types/node": "^22.8.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
